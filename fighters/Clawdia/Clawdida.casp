:AnimRunStart:
#Overriden from AnimRunStart
# CallParent() allows you to extend the overriden state by adding your behavior.
# Remove it to replace the default behavior with yours instead
S3:
	Sprite(RunStartStop, 1)
S3
	Sprite(RunStartStop, 0)
endif
:AnimRunStop:
