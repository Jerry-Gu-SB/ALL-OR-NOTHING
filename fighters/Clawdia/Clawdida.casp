:Variables:
## This is the Variables block, where you can store custom variables or overwrite defined ones.You can see all available default variables by activating 'Show All Variables' in the navigation panel.
:5L:
# Simple medium attack template
AttackRegister(Light, 5L)

# Adjust parameters here
AttackDamage(1000)
AttackDuration(20)

# Put your animation here
Anim(5L)

# Active frames and hitboxes
F10-12:
	Hitbox(0, 25000, 18000, 30000)
endif
:AnimRunStart:
#Overriden from AnimRunStart
# CallParent() allows you to extend the overriden state by adding your behavior.
# Remove it to replace the default behavior with yours instead
CallParent()
:AnimRunStop:
#Overriden from AnimRunStop
# CallParent() allows you to extend the overriden state by adding your behavior.
# Remove it to replace the default behavior with yours instead

CallParent()
:AnimStand:
#Overriden from AnimStand
# CallParent() allows you to extend the overriden state by adding your behavior.
# Remove it to replace the default behavior with yours instead

CallParent()
:j5H:
AttackRegister(AirHeavy, j5H)

# Adjust parameters here
AttackDamage(5000)
AttackDuration(60)

AttackFlag(Overhead)

# Put your animation here
Anim(j5H)

# Active frames and hitboxes

F10-50:
	AttackMomentumHit(2000, 0, 0, -8000)
	AttackKnockdown()
	AttackFlag(ForceLanding)
	Hitbox(-3000, 25000, 1000, 15000)

endif

ELanding:
	LAttackHasWhiffed:
		TransitionToFrame(Knockdown, 21, 1000000, True)
	endif
endif
